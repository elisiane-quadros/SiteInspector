# =============================================================
# SiteInspector — Template de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais:
#   Windows:      copy .env.example .env
#   Linux/macOS:  cp .env.example .env
# O arquivo .env NÃO é versionado (está no .gitignore).
# =============================================================

# Ambiente da aplicação: development | production
APP_ENV=development

# URLs do frontend autorizadas a chamar a API (separadas por vírgula)
# Em produção, coloque a URL do seu frontend na Vercel
ALLOWED_ORIGINS=http://localhost:5173

# Timeout (em segundos) para carregar a página alvo
REQUEST_TIMEOUT=30

# Máximo de elementos analisados por página
MAX_ELEMENTS=200

# Chave da API Groq — obtenha em https://console.groq.com
GROQ_API_KEY=
